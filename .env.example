# Supabase — from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Used by the contact server action to insert leads. NEVER expose client-side.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — lead-notification email (https://resend.com/api-keys)
RESEND_API_KEY=re_your_api_key
# Inbox that should receive new-lead emails.
LEAD_NOTIFY_EMAIL=owner@example.com
# Optional. "From" address — must be on a Resend-verified domain.
RESEND_FROM=Slab & Grain <leads@slabandgrain.com>
